# =====================================================
# ФУНКЦИЯ: безопасный SHAP extract
# =====================================================

def get_shap_values(shap_values, class_idx=1):
    """
    Унифицирует SHAP output:
    - regression -> array
    - binary classification -> list
    - multiclass -> list
    """
    if isinstance(shap_values, list):
        return shap_values[class_idx]
    return shap_values


# =====================================================
# ПРЕОБРАЗОВАНИЕ РАССТОЯНИЯ
# =====================================================

df_work[distance_col] = (
    df_work[distance_col]
    .astype(str)
    .str.replace(',', '.', regex=False)
    .str.extract(r'([\d\.]+)')[0]
)

df_work[distance_col] = pd.to_numeric(df_work[distance_col], errors='coerce')

# лог-трансформация (более интерпретируемо, чем винзоризация)
df_work[distance_col] = np.log1p(df_work[distance_col])

# =====================================================
# ГРУППИРОВКА РАССТОЯНИЯ
# =====================================================

distance_bins = [0, 4.6, 5.3, 6.2, 7.0, np.inf]
distance_labels = ['0-100', '100-200', '200-500', '500-1000', '1000+']

df_work['distance_group'] = pd.cut(
    np.expm1(df_work[distance_col]),
    bins=[0, 100, 200, 500, 1000, np.inf],
    labels=distance_labels,
    include_lowest=True
)

# =====================================================
# ПОДГОТОВКА X ДЛЯ SHAP
# =====================================================

X_shap = X.loc[df_work.index]

assert len(X_shap) == len(df_work), "X и df_work не синхронизированы"

