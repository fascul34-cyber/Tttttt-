)

# =====================================================
# ГЛОБАЛЬНАЯ ВАЖНОСТЬ (КОРРЕКТНАЯ ИНТЕРПРЕТАЦИЯ)
# =====================================================

importance = pd.DataFrame({
    'feature': X_shap.columns,
    'mean_abs_shap': np.abs(shap_values).mean(axis=0),
    'mean_shap': shap_values.mean(axis=0),
    'std_shap': shap_values.std(axis=0)
})

