])

# =====================================================
# ВЛИЯНИЕ РАССТОЯНИЯ ПО ГРУППАМ
# =====================================================

distance_effect = (
    pd.DataFrame({
        'distance_group': df_work['distance_group'],
        'shap': shap_df[distance_col]
    })
    .groupby('distance_group', observed=True)
    .agg(
        mean_shap=('shap', 'mean'),
        mean_abs_shap=('shap', lambda x: np.abs(x).mean()),
        count=('shap', 'size')
    )
    .reset_index()
)

distance_effect['mean_shap_per_obs'] = (
    distance_effect['mean_shap'] / distance_effect['count']
)

print("\nВЛИЯНИЕ РАССТОЯНИЯ ПО ГРУППАМ")
