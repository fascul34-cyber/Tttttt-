let
    Source = YourTable,

    // Типы
    #"Changed Type" = Table.TransformColumnTypes(
        Source,
        {
            {"station", type text},
            {"stop_date", type date},
            {"start_date", type date}
        }
    ),

    // Мин и макс даты
    MinDate = List.Min(#"Changed Type"[stop_date]),
    MaxDate = List.Max(#"Changed Type"[start_date]),

    // Список всех дат
    DateList = List.Dates(
        MinDate,
        Duration.Days(MaxDate - MinDate) + 1,
        #duration(1,0,0,0)
    ),

    DatesTable = Table.FromList(DateList, Splitter.SplitByNothing(), {"date"}),

    // Список станций
    Stations = Table.Distinct(
        Table.SelectColumns(#"Changed Type", {"station"})
    ),

    // Все комбинации station × date
    AddDates = Table.AddColumn(Stations, "Dates", each DatesTable),

    ExpandDates = Table.ExpandTableColumn(
        AddDates,
        "Dates",
        {"date"}
    ),

    // Проверка остановки
    AddFlag = Table.AddColumn(
        ExpandDates,
        "is_stop",
        (current) =>
            let
                Filtered =
                    Table.SelectRows(
                        #"Changed Type",
                        each
                            [station] = current[station]
                            and current[date] >= [stop_date]
                            and current[date] <= [start_date]
                    )
            in
                if Table.RowCount(Filtered) > 0 then 1 else 0,
        Int64.Type
    )

in
    AddFlag
